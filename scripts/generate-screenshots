#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SCREENSHOTS_DIR="$ROOT_DIR/screenshots"
MAD="$ROOT_DIR/target/release/mad"

# Build mad in release mode
echo "Building mad..."
cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" -p mad

# Ensure screenshots directory exists
mkdir -p "$SCREENSHOTS_DIR"

generate() {
  local name="$1"
  local md_file="$2"
  local width="$3"

  echo "Generating $name.png..."
  "$MAD" --no-code-background-color -w "$width" "$md_file" > "/tmp/mad-${name}.raw"
  termshot -f "$SCREENSHOTS_DIR/${name}.png" -C "$width" --raw-read "/tmp/mad-${name}.raw"
  rm -f "/tmp/mad-${name}.raw"
}

generate hero "$SCREENSHOTS_DIR/demo.md" 80
generate code "$SCREENSHOTS_DIR/code-example.md" 72
generate table "$SCREENSHOTS_DIR/table-example.md" 60

echo "Done. Screenshots written to $SCREENSHOTS_DIR/"
